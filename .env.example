# Sao chép thành .env và điền giá trị thật (không commit .env).

# Tên database phải trùng Atlas (ví dụ bạn dùng DB "test" thì thay .../test?...).
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/test?retryWrites=true&w=majority

# Chuỗi bí mật ký JWT — ít nhất 16 ký tự, tự tạo ngẫu nhiên.
JWT_SECRET=thay-bang-chuoi-bi-mat-dai-it-nhat-16-ky-tu

PORT=5000
CORS_ORIGIN=http://localhost:5173

# Gmail: bật 2FA → Google Account → Bảo mật → "Mật khẩu ứng dụng" → tạo mật khẩu
# 16 ký tự, dán vào SMTP_PASS (KHÔNG dùng mật khẩu đăng nhập Gmail thường).
#
# Nếu CHƯA điền SMTP_USER / SMTP_PASS: không có mail — mã OTP in ra TERMINAL
# nơi chạy `npm run dev` của be_clinic (không phải terminal fe_clinic).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=app-password-16-chars
# Tuỳ chọn: địa chỉ hiển thị người gửi (nên trùng SMTP_USER khi dùng Gmail)
SMTP_FROM=your.email@gmail.com
