# Chuỗi kết nối MongoDB (bắt buộc)
MONGODB_URI=mongodb://127.0.0.1:27017

# Tên database chứa collection thuốc
MONGO_DB_NAME=clinic

# Tên collection (bạn đã dùng: medicine)
MONGO_MED_COLLECTION=medicine

# User đăng nhập (mặc định users): cần email + mật khẩu bcrypt trong field password / passwordHash / hash, và userType
MONGO_USERS_COLLECTION=users

# Lịch khám (fe_clinic đặt lịch / danh sách của tôi — lưu Mongo)
MONGO_APPOINTMENTS_COLLECTION=appointments

# Danh mục chuyên khoa (specialtyID → specialtyName). Để trống DB = dùng MONGO_DB_NAME.
# MONGO_SPECIALTIES_DB_NAME=test
MONGO_SPECIALTIES_COLLECTION=specialties

# JWT (bắt buộc cho đăng nhập)
JWT_SECRET=thay-bang-chuoi-bi-mat-dai

# Một server dev: auth + thuốc + stub lịch (fe gọi :5000)
PORT=5000
