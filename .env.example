MONGODB_URI=
JWT_SECRET=
PORT=5000

# Gửi OTP (đăng ký, quên mật khẩu) và email xác nhận lịch — cần cả hai biến sau.
# Gmail: bật xác minh 2 bước → Tạo "Mật khẩu ứng dụng" → dán vào SMTP_PASS (không dùng mật khẩu đăng nhập thường).
SMTP_USER=
SMTP_PASS=
# Tuỳ chọn: địa chỉ hiển thị người gửi (mặc định = SMTP_USER)
# SMTP_FROM=noreply@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
